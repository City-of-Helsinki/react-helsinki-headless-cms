{
  "name": "@city-of-helsinki/react-helsinki-headless-cms",
  "version": "3.0.1",
  "description": "React components for displaying Headless CMS content according to guidelines set by HDS",
  "main": "cjs/index.js",
  "module": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "prepare": "husky",
    "dev": "yarn storybook",
    "dev:no-open": "yarn storybook --no-open",
    "typecheck": "tsc --project ./tsconfig.json --noEmit",
    "lint": "yarn eslint src && yarn prettier ./src -c",
    "lint-fix": "yarn eslint src --fix && yarn prettier ./src -w",
    "test": "vitest",
    "test:staged": "vitest related --passWithNoTests",
    "test-storybook": "test-storybook",
    "test:coverage": "vitest run --coverage",
    "build": "rollup -c --bundleConfigAsCjs",
    "docker:dev": "cross-env DOCKER_TARGET=development docker compose up",
    "docker:prod": "cross-env DOCKER_TARGET=production docker compose up",
    "docker:down": "docker compose down --remove-orphans",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate:graphql": "cross-env DOTENV_CONFIG_PATH=./.env graphql-codegen -r dotenv/config --config codegen.yml"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "files": [
    "dist/"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/cjs/index.js"
    },
    "./apollo": {
      "import": "./dist/apollo.js",
      "default": "./dist/cjs/apollo.js"
    },
    "./nextjs": {
      "import": "./dist/nextjs.js",
      "default": "./dist/cjs/nextjs.js"
    }
  },
  "repository": "https://github.com/City-of-Helsinki/react-helsinki-headless-cms.git",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/City-of-Helsinki/react-helsinki-headless-cms/issues"
  },
  "homepage": "https://github.com/City-of-Helsinki/react-helsinki-headless-cms#readme",
  "peerDependencies": {
    "@apollo/client": "^3.14.0",
    "hds-react": ">=4.8.1",
    "react": "^18",
    "react-dom": "^18"
  },
  "peerDependenciesMeta": {
    "@apollo/client": {
      "optional": true
    }
  },
  "//": {
    "Why are packages in resolutions?": {
      "hds-react/cookie": [
        "To fix https://github.com/City-of-Helsinki/react-helsinki-headless-cms/security/dependabot/28",
        "NOTE: This can be removed if hds-react starts to depend on >=v1 cookie"
      ],
      "minimatch": [
        "To fix https://github.com/City-of-Helsinki/react-helsinki-headless-cms/security/dependabot/80,",
        "https://github.com/City-of-Helsinki/react-helsinki-headless-cms/security/dependabot/77",
        "https://github.com/City-of-Helsinki/react-helsinki-headless-cms/security/dependabot/76"
      ],
      "picomatch": [
        "To fix vulnerable picomatch@2.3.1 (no 2.3.2 exists on npm) and consolidate all",
        "picomatch instances to a safe version. Overrides transitive 2.x requirements",
        "from micromatch, anymatch, @rollup/pluginutils v4, and 4.0.2/4.0.3 requirements."
      ]
    }
  },
  "resolutions": {
    "hds-react/cookie": "^0.7.2",
    "minimatch": "^10.2.3",
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@apollo/client": "^3.14.0",
    "@babel/core": "^7.28.0",
    "@babel/plugin-transform-runtime": "^7.28.0",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@chromatic-com/storybook": "^4.1.3",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "6.2.1",
    "@graphql-codegen/typescript": "^4.1.6",
    "@graphql-codegen/typescript-operations": "^4.6.1",
    "@graphql-codegen/typescript-react-apollo": "^4.4.1",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@storybook/addon-a11y": "^10.1.6",
    "@storybook/addon-docs": "^10.1.6",
    "@storybook/addon-links": "^10.1.6",
    "@storybook/addon-webpack5-compiler-babel": "^3.0.6",
    "@storybook/preset-scss": "^1.0.3",
    "@storybook/react-webpack5": "^10.1.6",
    "@storybook/test-runner": "^0.24.2",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.27",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "axe-playwright": "^2.2.2",
    "babel-loader": "^9.2.1",
    "cross-env": "^7.0.3",
    "crypto-browserify": "^3.12.1",
    "css-loader": "^6.11.0",
    "dotenv": "^17.4.1",
    "edit-json-file": "^1.8.1",
    "eslint": "^10.2.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "git-rev-sync": "^3.0.2",
    "globals": "^17.4.0",
    "graphql": "^16.12.0",
    "hds-react": "4.8.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.2.7",
    "msw-storybook-addon": "^2.0.6",
    "postcss": "^8.5.6",
    "postcss-scss": "^4.0.9",
    "prettier": "3.7.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "rollup": "^4.59.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-delete": "^3.0.2",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-includepaths": "^0.2.4",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-typescript2": "^0.36.0",
    "sass": "^1.95.1",
    "sass-loader": "^13.3.3",
    "storybook": "^10.2.10",
    "style-loader": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4",
    "vitest-axe": "^0.1.0",
    "webpack": "^5.104.1"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "doctoc": "^2.3.0",
    "hds-design-tokens": "^4.8.1",
    "html-entities": "^2.6.0",
    "html-react-parser": "^5.2.5",
    "isomorphic-dompurify": "^2.36.0",
    "lodash-es": "^4.17.23",
    "msw": "^2.12.4"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,cjs,mjs}": [
      "eslint --fix",
      "prettier --write",
      "yarn test:staged"
    ]
  }
}
